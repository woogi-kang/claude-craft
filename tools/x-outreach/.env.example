# Burner Account (for crawling)
BURNER_X_USERNAME=
BURNER_X_PASSWORD=

# Master Account Playwright session (for reply and DM)
MASTER_X_USERNAME=
MASTER_X_PASSWORD=

# DM Encryption Passcode (4-digit PIN for X message encryption)
# Leave empty if your account does not use DM encryption
X_DM_ENCRYPTION_PASSCODE=

# Gemini API
GEMINI_API_KEY=

# PostgreSQL
DATABASE_URL=postgresql://user:pass@localhost:5432/outreach
