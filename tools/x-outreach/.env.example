# Per-Persona Account Credentials (one per account_id in personas/accounts.yaml)
MASTER_A_USERNAME=
MASTER_A_PASSWORD=
MASTER_B_USERNAME=
MASTER_B_PASSWORD=
MASTER_C_USERNAME=
MASTER_C_PASSWORD=
MASTER_D_USERNAME=
MASTER_D_PASSWORD=
MASTER_E_USERNAME=
MASTER_E_PASSWORD=

# DM Encryption Passcode (4-digit PIN for X message encryption)
# Leave empty if your account does not use DM encryption
X_DM_ENCRYPTION_PASSCODE=

# Gemini API key (only needed if using gemini SDK provider, not gemini_cli)
# CLI-based providers (codex, gemini_cli) do not require API keys.
GEMINI_API_KEY=

# PostgreSQL
DATABASE_URL=postgresql://user:pass@localhost:5432/outreach

# Oxylabs Residential Proxy (per-persona account)
# Base username example: customer-master_a_xxxxx
OXYLABS_PROXY_SERVER=pr.oxylabs.io:7777
OXYLABS_PROXY_COUNTRY=JP
OXYLABS_PROXY_CITY=tokyo

OXYLABS_MASTER_A_PROXY_USERNAME=
OXYLABS_MASTER_A_PROXY_PASSWORD=
# Optional per-account geo override (fallback to OXYLABS_PROXY_COUNTRY/CITY)
OXYLABS_MASTER_A_PROXY_COUNTRY=
OXYLABS_MASTER_A_PROXY_CITY=
OXYLABS_MASTER_B_PROXY_USERNAME=
OXYLABS_MASTER_B_PROXY_PASSWORD=
OXYLABS_MASTER_B_PROXY_COUNTRY=
OXYLABS_MASTER_B_PROXY_CITY=
OXYLABS_MASTER_C_PROXY_USERNAME=
OXYLABS_MASTER_C_PROXY_PASSWORD=
OXYLABS_MASTER_C_PROXY_COUNTRY=
OXYLABS_MASTER_C_PROXY_CITY=
OXYLABS_MASTER_D_PROXY_USERNAME=
OXYLABS_MASTER_D_PROXY_PASSWORD=
OXYLABS_MASTER_D_PROXY_COUNTRY=
OXYLABS_MASTER_D_PROXY_CITY=
OXYLABS_MASTER_E_PROXY_USERNAME=
OXYLABS_MASTER_E_PROXY_PASSWORD=
OXYLABS_MASTER_E_PROXY_COUNTRY=
OXYLABS_MASTER_E_PROXY_CITY=
